+	if (win32_rexeced_flag)
+		argc = saved_argc - 1; // override '-R'
+	else {
+		char **tmp = xcalloc(saved_argc + 1 + 1, sizeof(*saved_argv)); // 1 - extra argument "-y/-z", 1 - NULL
+		int i = 0;
+		for (i = 0; (int)i < saved_argc; i++) {
+			tmp[i] = xstrdup(saved_argv[i]);
+			free(saved_argv[i]);
+		}
+
+		free(saved_argv);
+		argv = saved_argv = tmp;
+		argc = saved_argc;
+	}
+
+	if (authenticated)
+		argv[argc] = "-z";
+	else
+		argv[argc] = "-y";
+
+	return argv;
+}
