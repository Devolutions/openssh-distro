+
+static void
+recv_autxctx_state(Authctxt *auth, int fd)
+{
+	struct sshbuf *m;
+	u_char *cp, ver, *user;
+	size_t user_len;
+	int r;
+
+	debug3("%s: entering fd = %d", __func__, fd);
+
+	if ((m = sshbuf_new()) == NULL)
+		fatal("%s: sshbuf_new failed", __func__);
+	if (ssh_msg_recv(fd, m) == -1)
